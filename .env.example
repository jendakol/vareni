# Required
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# Database — Docker Compose sets this automatically, only needed for standalone deployment
#DATABASE_URL=postgresql://cooking:cooking@localhost:5432/cookingapp

# Optional
BASE_URL=http://localhost:8080
JWT_EXPIRY_HOURS=720
PUSH_NOTIFY_HOUR=20

# Push notifications (optional — generate with web-push library)
#VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=
#VAPID_CONTACT=mailto:you@example.com

# Recipe discovery (optional — requires ONNX model, see README)
#EMBEDDING_MODEL_DIR=./models/all-MiniLM-L6-v2
#DISCOVERY_ENABLED=true

# Log API token (optional — enables POST /api/log for Home Assistant)
#LOG_API_TOKEN=

# Metrics — refresh interval for the recipes_total gauge (DB COUNT(*) cadence)
#METRICS_GAUGE_REFRESH_SECS=60
